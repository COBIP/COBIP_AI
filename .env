# true: MockRetriever + MockLLMClient / false: Qdrant + vLLM 실연동
USE_MOCK=true

# vLLM 서버
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-Coder-14B-Instruct
VLLM_MAX_TOKENS=1024
VLLM_TEMPERATURE=0.3

# Qdrant 벡터 DB
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION_NAME=cobip_chunks

# FastAPI 서버
HOST=0.0.0.0
PORT=8000
