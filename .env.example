# =========================
# LLM Provider
# =========================
LLM_PROVIDER=ollama

# Docker Compose 내부에서는 Ollama 서비스명 사용
OLLAMA_BASE_URL=http://ollama:11434/v1

# FastAPI만 docker run으로 실행하고 Ollama가 호스트에서 실행 중이면:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

OLLAMA_MODEL=qwen2.5-coder:1.5b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# =========================
# RAG / Qdrant / Embedding (6-3 설정, Retriever 미연동)
# =========================
RAG_ENABLED=false
RAG_TOP_K=3

# Compose 내부 기본
QDRANT_URL=http://qdrant:6333
# FastAPI만 호스트에서 docker run 할 때 Qdrant가 호스트에 있으면 예:
# QDRANT_URL=http://host.docker.internal:6333

QDRANT_COLLECTION=cobip_knowledge
EMBEDDING_MODEL=BAAI/bge-m3

# =========================
# App
# =========================
APP_NAME=COBIP AI Server
APP_ENV=local
DEBUG=true
API_PREFIX=/ai

# =========================
# Infrastructure
# =========================
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=30
