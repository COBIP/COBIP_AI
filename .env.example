APP_ENV=local
API_PREFIX=/ai
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# LLM provider.
# - ollama: use Ollama OpenAI-compatible API
# - vllm: use vLLM OpenAI-compatible API (kept for compatibility)
LLM_PROVIDER=ollama

# OpenAI-compatible endpoint.
# The VLLM_* names are kept for backward compatibility, but this URL can point to Ollama too.
# For FastAPI running in Docker and Ollama running on the host:
VLLM_BASE_URL=http://host.docker.internal:11434/v1
# For Ollama running as a service in the same docker-compose network:
# VLLM_BASE_URL=http://ollama:11434/v1

# Model name to use for /chat/completions.
VLLM_MODEL=qwen2.5-coder:1.5b
VLLM_MODEL_NAME=qwen2.5-coder:1.5b
LLM_MODEL_NAME=qwen2.5-coder:1.5b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=30
